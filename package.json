{
  "name": "sonicmotion",
  "version": "4.0.1",
  "description": "Lightweight audio-reactive DOM animation library. Sincroniza movimientos web con música usando Stems y Web Audio API. Zero dependencies.",
  "main": "src/sonicmotion.js",
  "module": "src/sonicmotion.js",
  "type": "module",
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild src/sonicmotion.js --bundle --minify --format=esm --outfile=dist/sonicmotion.min.js",
    "dev": "esbuild src/sonicmotion.js --bundle --format=esm --outfile=dist/sonicmotion.js --servedir=demo --serve=8080"
  },
  "keywords": [
    "audio-reactive web motion",
    "music visualization library JS",
    "librería para detectar sonido",
    "animación web con música",
    "DOM audio animation",
    "Web Audio API stems",
    "frontend reactive audio",
    "sound frequency visualizer",
    "visualizador de música web",
    "music synced UI",
    "javascript audio stems",
    "audio-driven DOM effects",
    "sonicmotion"
  ],
  "author": "axscq",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
